{
  "name": "acp-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc -b && vite build && tsc -p server/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/dist/index.js",
    "setup:wsl-service": "bash ops/systemd/install-acp-monitor-service.sh",
    "setup:desktop-shortcut": "bash ops/wsl/install-windows-desktop-shortcut.sh"
  },
  "dependencies": {
    "express": "^5.1.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "strip-ansi": "^7.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
